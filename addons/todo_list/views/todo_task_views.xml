<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Tree view for todo tasks -->
        <record id="view_todo_task_tree" model="ir.ui.view">
            <field name="name">todo.task.tree</field>
            <field name="model">todo.task</field>
            <field name="arch" type="xml">
                <tree string="Todo Tasks" decoration-muted="status == 'completed'">
                    <field name="title"/>
                    <field name="status"/>
                    <field name="due_date"/>
                    <field name="create_date"/>
                    <button name="toggle_status" type="object" 
                            icon="fa-check-circle text-success" 
                            attrs="{'invisible': [('status', '=', 'completed')]}"
                            title="Mark as completed"/>
                    <button name="toggle_status" type="object" 
                            icon="fa-undo text-warning" 
                            attrs="{'invisible': [('status', '=', 'pending')]}"
                            title="Mark as pending"/>
                </tree>
            </field>
        </record>
        
        <!-- Form view for todo tasks -->
        <record id="view_todo_task_form" model="ir.ui.view">
            <field name="name">todo.task.form</field>
            <field name="model">todo.task</field>
            <field name="arch" type="xml">
                <form string="Todo Task">
                    <header>
                        <button name="toggle_status" type="object" 
                                string="Mark as Completed" 
                                class="btn-primary"
                                attrs="{'invisible': [('status', '=', 'completed')]}"/>
                        <button name="toggle_status" type="object" 
                                string="Mark as Pending" 
                                class="btn-secondary"
                                attrs="{'invisible': [('status', '=', 'pending')]}"/>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="title"/>
                                <field name="due_date"/>
                            </group>
                            <group>
                                <field name="user_id" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="description" placeholder="Add task description..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Search view for todo tasks -->
        <record id="view_todo_task_search" model="ir.ui.view">
            <field name="name">todo.task.search</field>
            <field name="model">todo.task</field>
            <field name="arch" type="xml">
                <search string="Search Todo Tasks">
                    <field name="title"/>
                    <field name="description"/>
                    <filter name="pending" string="Pending" domain="[('status', '=', 'pending')]"/>
                    <filter name="completed" string="Completed" domain="[('status', '=', 'completed')]"/>
                    <filter name="overdue" string="Overdue" 
                            domain="[('due_date', '&lt;', context_today().strftime('%Y-%m-%d')), ('status', '=', 'pending')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_status" string="Status" domain="[]" context="{'group_by': 'status'}"/>
                        <filter name="group_due_date" string="Due Date" domain="[]" context="{'group_by': 'due_date'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Action for todo tasks -->
        <record id="action_todo_task" model="ir.actions.act_window">
            <field name="name">Todo Tasks</field>
            <field name="res_model">todo.task</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_pending': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first todo task!
                </p>
                <p>
                    Track your tasks and never forget what you need to do.
                    You can also use the local storage interface for offline task management.
                </p>
            </field>
        </record>
        
        <!-- Client action for local storage interface -->
        <record id="action_todo_list_client" model="ir.actions.client">
            <field name="name">Todo List (Local Storage)</field>
            <field name="tag">todo_list_client</field>
            <field name="target">current</field>
        </record>
        
    </data>
</odoo>