<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Service Order Sequence -->
        <record id="seq_service_order" model="ir.sequence">
            <field name="name">Service Order</field>
            <field name="code">service.order</field>
            <field name="prefix">SO/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <!-- Customer Equipment Sequence -->
        <record id="seq_customer_equipment" model="ir.sequence">
            <field name="name">Customer Equipment</field>
            <field name="code">customer.equipment</field>
            <field name="prefix">EQ/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>