<odoo>
    <record id="view_equipment_tree" model="ir.ui.view">
        <field name="name">repair.equipment.tree</field>
        <field name="model">repair.equipment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="location"/>
            </tree>
        </field>
    </record>
    <record id="view_equipment_form" model="ir.ui.view">
        <field name="name">repair.equipment.form</field>
        <field name="model">repair.equipment</field>
        <field name="arch" type="xml">
            <form>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="location"/>
            </form>
        </field>
    </record>
</odoo>