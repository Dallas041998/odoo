<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Equipment Form View -->
    <record id="view_equipment_form" model="ir.ui.view">
        <field name="name">repair.equipment.form</field>
        <field name="model">repair.equipment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="serial_number"/>
                        <field name="location"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Equipment Tree View -->
    <record id="view_equipment_tree" model="ir.ui.view">
        <field name="name">repair.equipment.tree</field>
        <field name="model">repair.equipment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="location"/>
            </tree>
        </field>
    </record>

    <!-- Equipment Action -->
    <record id="action_equipment" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">repair.equipment</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first equipment
            </p>
        </field>
    </record>
</odoo>    