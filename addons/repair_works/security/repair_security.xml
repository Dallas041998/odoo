<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="repair_group_user" model="res.groups">
            <field name="name">User: Repair Works Access</field>
            <field name="category_id" ref="base.module_category_services"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
        <record id="repair_group_manager" model="res.groups">
            <field name="name">Administrator: Repair Works Manager</field>
            <field name="implied_ids" eval="[(4, ref('repair_group_user'))]"/>
            <field name="category_id" ref="base.module_category_services"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>